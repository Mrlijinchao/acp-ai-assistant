{
	"compilerOptions": {
		"module": "Node16",
		"target": "ES2022",
		"lib": [
			"ES2022"
		],
		"outDir": "out",
		"sourceMap": true,
		"rootDir": "src",
		"strict": true,   /* enable all strict type-checking options */
		"esModuleInterop": true,
    	"skipLibCheck": true,
    	"forceConsistentCasingInFileNames": true,
    	"resolveJsonModule": true
	},
	"exclude": ["node_modules", ".vscode-test", "out"]
}
