# 自动检测文本文件，并规范化行尾
* text=auto

# 源代码文件强制使用 LF
*.js text eol=lf
*.ts text eol=lf
*.jsx text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.vue text eol=lf
*.py text eol=lf
*.go text eol=lf
*.rs text eol=lf

# 配置文件强制使用 LF
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.conf text eol=lf
*.sh text eol=lf

# Shell 脚本必须 LF（否则无法执行）
*.sh text eol=lf
*.bash text eol=lf

# Windows 批处理必须 CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# 标记为二进制文件（避免 Git 尝试转换）
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.pdf binary
*.zip binary
*.tar.gz binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary

# 特定工具文件
package-lock.json text eol=lf
yarn.lock text eol=lf
pnpm-lock.yaml text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
.editorconfig text eol=lf
.prettierrc text eol=lf
.eslintrc text eol=lf